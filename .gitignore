# =========================
# Weird Lab / 怪題研究所
# Local development ignores
# =========================


# =========================
# Secrets / environment
# =========================
.env
.env.*
!.env.example

*.pem
*.key
*.crt
*.p12
*.pfx

# API / OAuth secrets
*secret*
*token*
*credential*
credentials.json
client_secret.json

# Keep examples
!*secret*.example
!*token*.example
!*credential*.example


# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/
ENV/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

*.egg-info/
dist/
build/


# =========================
# FastAPI / backend runtime
# =========================
backend/.env
backend/.env.*
backend/.venv/
backend/venv/
backend/__pycache__/
backend/app/__pycache__/

# local SQLite database
backend/data/*.db
backend/data/*.sqlite
backend/data/*.sqlite3
data/*.db
data/*.sqlite
data/*.sqlite3

# keep folder structure if you add .gitkeep
!backend/data/.gitkeep
!data/.gitkeep


# =========================
# Node / Vue / Vite frontend
# =========================
node_modules/
frontend/node_modules/

frontend/dist/
frontend/build/
frontend/.vite/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

package-lock.json
!frontend/package-lock.json


# =========================
# Local generated product outputs
# =========================
exports/
prototypes/
experiments/
logs/
runs/
scratch/

# If you want to keep folder placeholders
!exports/.gitkeep
!prototypes/.gitkeep
!experiments/.gitkeep
!logs/.gitkeep


# =========================
# Repo probe / cloned repos
# =========================
repo-probes/
cloned-repos/
external-repos/
tmp-repos/
temp-repos/


# =========================
# Scheduler / runtime state
# =========================
*.lock
*.pid
scheduler-state.json
runtime-state.json


# =========================
# OS / editor
# =========================
.DS_Store
Thumbs.db
desktop.ini

.vscode/
.idea/

*.swp
*.swo


# =========================
# Test / temporary files
# =========================
tmp/
temp/
.cache/

*.tmp
*.temp
*.bak
*.backup


# =========================
# Large archives / generated packages
# =========================
*.zip
*.7z
*.rar
*.tar
*.tar.gz

# Allow intentionally committed release notes/docs if needed
!docs/**/*.zip


# =========================
# ChatGPT / Codex local artifacts
# =========================
codex-*.txt
*_prompt.txt
local_gpt_logs/
chatgpt_profile/
edge_debug_profile/


# =========================
# Do not ignore source/config docs
# =========================
!README.md
!AGENTS.md
!docs/
!backend/requirements.txt
!frontend/package.json
!frontend/package-lock.json